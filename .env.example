# ─────────────────────────────────────────────────────────────────────
# ECRN environment variables
#
# For V1 the app runs entirely on mock data — none of these values
# are required to start `npm run dev`. They are listed here so the
# integration points are documented and ready when you wire in real
# services (Batch 7+).
# ─────────────────────────────────────────────────────────────────────

# Supabase — set these once you create a project. The app will
# automatically switch from the mock store to Supabase when both
# the URL and anon key are present.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist — comma-separated emails. Any new signup matching
# one of these emails is auto-promoted to the `admin` role.
NEXT_PUBLIC_ADMIN_EMAILS=aaron@skyway.media

# Branding / share links
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ECRN

# Notifications (Batch 7) — leave blank to log to console.
SENDGRID_API_KEY=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Bullhorn (Batch 8) — placeholder, not used in V1.
BULLHORN_CLIENT_ID=
BULLHORN_CLIENT_SECRET=
BULLHORN_REFRESH_TOKEN=
